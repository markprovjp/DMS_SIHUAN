NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dms_ai_admin
REDIS_URL=redis://localhost:6379

MOBIWORK_API_BASE=https://openapi.mobiwork.vn
MOBIWORK_USER_ID=your_user_id_here
MOBIWORK_TOKEN=your_token_here

AI_PROVIDER=9router
AI_BASE_URL=https://qrouter.online/v1
AI_WIRE_API=responses
AI_API_KEY=replace_with_gateway_key
AI_TEXT_MODEL=cx/gpt-5.5
AI_VISION_MODEL=cx/gpt-5.5
AI_REASONING_EFFORT=high
AI_VERBOSITY=medium

JWT_SECRET=change_me_to_a_secure_random_string_in_production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

TIMEZONE=Asia/Bangkok
DEFAULT_SHIFT_START=08:00
DEFAULT_LATE_AFTER=08:15
DEFAULT_SHIFT_END=17:00
DEFAULT_MIN_WORK_HOURS=7.5

# Production-only (see docs/secret-policy.md)
# - JWT_SECRET must be ≥ 32 random bytes in production
# - APP_URL must be a specific origin (no wildcards) in production
# - See docs/deployment-runbook.md for full deployment guide
